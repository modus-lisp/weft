(define-decoder "big5" (bytes)
  (let* ((n (length bytes))
         (result (make-array n :element-type 'character :fill-pointer 0))
         (i 0))
    (labels ((emit (ch)
               (vector-push-extend ch result))
             (replacement ()
               (emit (code-char #xfffd))))
      (declare (inline emit replacement))
      (loop while (< i n) do
        (let ((b (aref bytes i)))
          (cond
            ((< b 128)
             (emit (code-char b))
             (incf i))
            ((and (<= #xA1 b #xF9) (/= b #xC8))
             ;; potential lead byte
             (if (< (1+ i) n)
                 (let ((lo (aref bytes (1+ i))))
                   (if (or (<= #x40 lo #x7E)
                           (<= #xA1 lo #xFE))
                       ;; valid two-byte sequence
                       (let ((cp (gethash (+ (ash b 8) lo) +big5-map+)))
                         (if cp
                             (emit (code-char cp))
                             (progn (replacement) (replacement)))
                         (incf i 2))
                       ;; invalid trail byte
                       (progn (replacement) (incf i))))
                 ;; truncated at end
                 (progn (replacement) (incf i))))
            (t
             ;; non-ASCII, non-lead byte -> U+FFFD
             (replacement)
             (incf i))))))
    (coerce result 'string)))
