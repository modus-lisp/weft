;;;; src/encoding/iso-8859-2.lisp — iso-8859-2 decoder (ISO 8859-2 / Latin-2).
(in-package #:weft.encoding)

(defparameter +iso-8859-2-map+
  (load-time-value
   (let ((m (make-array 256 :element-type 'character)))
     (dotimes (b 256 m)
       (setf (aref m b)
             (code-char
              (case b
                (#x80 #x80) (#x81 #x81) (#x82 #x82) (#x83 #x83)
                (#x84 #x84) (#x85 #x85) (#x86 #x86) (#x87 #x87)
                (#x88 #x88) (#x89 #x89) (#x8a #x8a) (#x8b #x8b)
                (#x8c #x8c) (#x8d #x8d) (#x8e #x8e) (#x8f #x8f)
                (#x90 #x90) (#x91 #x91) (#x92 #x92) (#x93 #x93)
                (#x94 #x94) (#x95 #x95) (#x96 #x96) (#x97 #x97)
                (#x98 #x98) (#x99 #x99) (#x9a #x9a) (#x9b #x9b)
                (#x9c #x9c) (#x9d #x9d) (#x9e #x9e) (#x9f #x9f)
                (#xa0 #xa0) (#xa1 #x0104) (#xa2 #x02d8) (#xa3 #x0141)
                (#xa4 #xa4)   (#xa5 #x013d) (#xa6 #x015a) (#xa7 #xa7)
                (#xa8 #xa8)   (#xa9 #x0160) (#xaa #x015e) (#xab #x0164)
                (#xac #x0179) (#xad #xad)   (#xae #x017d) (#xaf #x017b)
                (#xb0 #xb0)   (#xb1 #x0105) (#xb2 #x02db) (#xb3 #x0142)
                (#xb4 #xb4)   (#xb5 #x013e) (#xb6 #x015b) (#xb7 #x02c7)
                (#xb8 #xb8)   (#xb9 #x0161) (#xba #x015f) (#xbb #x0165)
                (#xbc #x017a) (#xbd #x02dd) (#xbe #x017e) (#xbf #x017c)
                (#xc0 #x0154) (#xc1 #xc1)   (#xc2 #xc2)   (#xc3 #x0102)
                (#xc4 #xc4)   (#xc5 #x0139) (#xc6 #x0106) (#xc7 #xc7)
                (#xc8 #x010c) (#xc9 #xc9)   (#xca #x0118) (#xcb #xcb)
                (#xcc #x011a) (#xcd #xcd)   (#xce #xce)   (#xcf #x010e)
                (#xd0 #x0110) (#xd1 #x0143) (#xd2 #x0147) (#xd3 #xd3)
                (#xd4 #xd4)   (#xd5 #x0150) (#xd6 #xd6)   (#xd7 #xd7)
                (#xd8 #x0158) (#xd9 #x016e) (#xda #xda)   (#xdb #x0170)
                (#xdc #xdc)   (#xdd #xdd)   (#xde #x0162) (#xdf #xdf)
                (#xe0 #x0155) (#xe1 #xe1)   (#xe2 #xe2)   (#xe3 #x0103)
                (#xe4 #xe4)   (#xe5 #x013a) (#xe6 #x0107) (#xe7 #xe7)
                (#xe8 #x010d) (#xe9 #xe9)   (#xea #x0119) (#xeb #xeb)
                (#xec #x011b) (#xed #xed)   (#xee #xee)   (#xef #x010f)
                (#xf0 #x0111) (#xf1 #x0144) (#xf2 #x0148) (#xf3 #xf3)
                (#xf4 #xf4)   (#xf5 #x0151) (#xf6 #xf6)   (#xf7 #xf7)
                (#xf8 #x0159) (#xf9 #x016f) (#xfa #xfa)   (#xfb #x0171)
                (#xfc #xfc)   (#xfd #xfd)   (#xfe #x0163) (#xff #x02d9)
                (otherwise b))))))
   t))

(define-decoder "iso-8859-2" (bytes)
  (map 'string (lambda (b) (aref +iso-8859-2-map+ b)) bytes))